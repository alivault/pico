{
  "name": "@alivault/pico",
  "version": "0.7.1",
  "description": "A local, keyboard-friendly browser workspace for Pi coding-agent sessions.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "pico-app": "bin/pico.mjs"
  },
  "files": [
    ".output",
    "bin",
    "scripts/patch-react-jsx-dev-runtime.mjs",
    "scripts/release.mjs",
    "public/screenshots",
    "vendor/node-domexception",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alivault/pico.git"
  },
  "homepage": "https://github.com/alivault/pico#readme",
  "bugs": {
    "url": "https://github.com/alivault/pico/issues"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && node ./scripts/patch-react-jsx-dev-runtime.mjs",
    "start": "node ./bin/pico.mjs",
    "prepack": "pnpm build",
    "preview": "vp preview",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "release": "node ./scripts/release.mjs",
    "update:pi": "pnpm update @earendil-works/pi-coding-agent --latest"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.74.0",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "encoding-sniffer": "1.0.2",
    "node-domexception": "file:./vendor/node-domexception"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@pierre/diffs": "^1.1.20",
    "@pierre/trees": "1.0.0-beta.3",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/pacer": "^0.21.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/router-plugin": "^1.166.13",
    "@tanstack/store": "^0.11.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "diff": "^9.0.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "react-scan": "^0.5.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "sugar-high": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-tsconfig-paths": "^5.1.4",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.33.0"
}
